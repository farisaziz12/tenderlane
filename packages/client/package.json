{
  "name": "@tenderlane/client",
  "version": "0.1.0-alpha.1",
  "description": "Headless checkout client with reactive state machine for Tenderlane",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farisaziz12/tenderlane.git",
    "directory": "packages/client"
  },
  "homepage": "https://github.com/farisaziz12/tenderlane#readme",
  "bugs": "https://github.com/farisaziz12/tenderlane/issues",
  "author": "Faris Aziz",
  "keywords": [
    "payments",
    "checkout",
    "headless",
    "state-machine",
    "tenderlane"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tenderlane/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}

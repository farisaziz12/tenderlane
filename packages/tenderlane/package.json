{
  "name": "tenderlane",
  "version": "0.1.0-alpha.1",
  "description": "Reactive payment orchestration for modern web apps",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./stripe": {
      "types": "./dist/stripe.d.ts",
      "import": "./dist/stripe.js"
    },
    "./stripe/server": {
      "types": "./dist/stripe-server.d.ts",
      "import": "./dist/stripe-server.js"
    },
    "./stripe/react": {
      "types": "./dist/stripe-react.d.ts",
      "import": "./dist/stripe-react.js"
    },
    "./polar": {
      "types": "./dist/polar.d.ts",
      "import": "./dist/polar.js"
    },
    "./polar/server": {
      "types": "./dist/polar-server.d.ts",
      "import": "./dist/polar-server.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farisaziz12/tenderlane.git",
    "directory": "packages/tenderlane"
  },
  "homepage": "https://github.com/farisaziz12/tenderlane#readme",
  "bugs": "https://github.com/farisaziz12/tenderlane/issues",
  "author": "Faris Aziz",
  "scripts": {
    "build": "rm -rf dist && tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tenderlane/core": "workspace:*",
    "@tenderlane/client": "workspace:*",
    "@tenderlane/react": "workspace:*",
    "@tenderlane/stripe": "workspace:*",
    "@tenderlane/polar": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "stripe": ">=14.0.0",
    "@stripe/stripe-js": ">=2.0.0",
    "@stripe/react-stripe-js": ">=2.0.0",
    "@polar-sh/sdk": ">=0.30.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "stripe": {
      "optional": true
    },
    "@stripe/stripe-js": {
      "optional": true
    },
    "@stripe/react-stripe-js": {
      "optional": true
    },
    "@polar-sh/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "keywords": [
    "payments",
    "stripe",
    "checkout",
    "orchestration",
    "react",
    "typescript"
  ]
}

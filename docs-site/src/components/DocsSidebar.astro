---
interface Item {
  label: string;
  slug: string;
}
interface Group {
  label: string;
  items: Item[];
}
interface Props {
  current: string;
  groups: Group[];
}
const { current, groups } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<aside class="docs-sidebar">
  <div class="docs-sidebar-inner">
    {groups.map((group) => (
      <div>
        <div class="t-cap" style="margin-bottom:10px;color:var(--text-3)">{group.label}</div>
        <ul>
          {group.items.map((item) => {
            const active = current === item.slug;
            return (
              <li>
                <a href={`${base}/docs/${item.slug}`} data-active={active ? 'true' : 'false'}>
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </div>
</aside>

<style>
  .docs-sidebar {
    width: 260px;
    flex-shrink: 0;
    border-right: 1px solid var(--line-1);
    padding: 32px 24px 80px;
    position: sticky;
    top: 60px;
    align-self: flex-start;
    max-height: calc(100vh - 60px);
    overflow-y: auto;
  }
  .docs-sidebar-inner {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .docs-sidebar ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .docs-sidebar a {
    display: block;
    padding: 5px 10px;
    margin: 0 -10px;
    border-radius: 6px;
    font-size: 13px;
    color: var(--text-1);
  }
  .docs-sidebar a:hover {
    color: var(--text-0);
  }
  .docs-sidebar a[data-active='true'] {
    color: var(--accent);
    background: color-mix(in oklab, var(--accent) 10%, transparent);
    font-weight: 500;
  }
  @media (max-width: 1000px) {
    .docs-sidebar {
      display: none;
    }
  }
</style>

---
import Icon from './Icons.astro';

interface Item {
  label: string;
  slug: string;
}
interface Group {
  label: string;
  items: Item[];
}
interface Props {
  current: string;
  groups: Group[];
}
const { current, groups } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class="docs-sidebar-backdrop side-drawer-backdrop" id="docs-sidebar-backdrop"></div>
<aside class="docs-sidebar" id="docs-sidebar">
  <div class="docs-sidebar-head">
    <span class="t-cap" style="color:var(--text-3)">Navigation</span>
    <button class="docs-drawer-close" id="docs-sidebar-close" aria-label="Close menu">
      <Icon name="close" size={16} />
    </button>
  </div>
  <div class="docs-sidebar-inner">
    {groups.map((group) => (
      <div>
        <div class="t-cap" style="margin-bottom:10px;color:var(--text-3)">{group.label}</div>
        <ul>
          {group.items.map((item) => {
            const active = current === item.slug;
            return (
              <li>
                <a href={`${base}/docs/${item.slug}`} data-active={active ? 'true' : 'false'}>
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </div>
</aside>

<style>
  .docs-sidebar {
    width: 260px;
    flex-shrink: 0;
    border-right: 1px solid var(--line-1);
    padding: 32px 24px 80px;
    position: sticky;
    top: 60px;
    align-self: flex-start;
    max-height: calc(100vh - 60px);
    overflow-y: auto;
  }
  .docs-sidebar-head {
    display: none;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  .docs-drawer-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--line-2);
    border-radius: 8px;
    background: transparent;
    color: var(--text-0);
    cursor: pointer;
  }
  .docs-sidebar-inner {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .docs-sidebar ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .docs-sidebar a {
    display: block;
    padding: 5px 10px;
    margin: 0 -10px;
    border-radius: 6px;
    font-size: 13px;
    color: var(--text-1);
  }
  .docs-sidebar a:hover {
    color: var(--text-0);
  }
  .docs-sidebar a[data-active='true'] {
    color: var(--accent);
    background: color-mix(in oklab, var(--accent) 10%, transparent);
    font-weight: 500;
  }
  .docs-sidebar-backdrop {
    display: none;
  }

  @media (max-width: 1024px) {
    .docs-sidebar {
      position: fixed;
      inset: 0 auto 0 0;
      top: 0;
      width: min(320px, 86vw);
      max-height: none;
      height: 100dvh;
      border-right: 1px solid var(--line-2);
      background: var(--bg-1);
      padding: 20px 20px 80px;
      padding-top: max(20px, env(safe-area-inset-top));
      padding-left: max(20px, env(safe-area-inset-left));
      padding-bottom: max(80px, env(safe-area-inset-bottom));
      z-index: 100;
      transform: translateX(-100%);
      transition: transform 0.2s ease;
      box-shadow: 0 0 0 1px var(--line-1), 0 24px 60px rgba(0, 0, 0, 0.4);
    }
    .docs-sidebar[data-open='true'] {
      transform: translateX(0);
    }
    .docs-sidebar-head {
      display: flex;
    }
    .docs-sidebar-backdrop {
      display: block;
    }
  }
</style>

<script>
  const sidebar = document.getElementById('docs-sidebar');
  const backdrop = document.getElementById('docs-sidebar-backdrop');
  const close = document.getElementById('docs-sidebar-close');

  const shut = () => {
    sidebar?.setAttribute('data-open', 'false');
    backdrop?.setAttribute('data-open', 'false');
    document.body.style.overflow = '';
  };

  close?.addEventListener('click', shut);
  backdrop?.addEventListener('click', shut);
  sidebar?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', shut);
  });

  // Expose open() globally so DocsLayout sub-header button can trigger it.
  (window as any).__tenderlaneOpenSidebar = () => {
    sidebar?.setAttribute('data-open', 'true');
    backdrop?.setAttribute('data-open', 'true');
    document.body.style.overflow = 'hidden';
  };
</script>

---
import Icon from './Icons.astro';

interface Props {
  filename?: string;
  lang?: string;
  lineNumbers?: boolean;
  copy?: boolean;
}
const { filename, lang = 'tsx', lineNumbers = true, copy = true } = Astro.props;
---

<div class="code">
  <div class="code-head">
    <span style="font-family:var(--font-mono);font-size:12px;color:var(--text-2)">
      {filename ?? lang}
    </span>
    {copy && (
      <button class="btn btn-link copy-btn" style="padding:4px;color:var(--text-2)" aria-label="Copy">
        <Icon name="copy" size={13} />
      </button>
    )}
  </div>
  <div class="code-body">
    <pre data-line-numbers={lineNumbers ? 'true' : 'false'}><slot /></pre>
  </div>
</div>

<style is:global>
  pre[data-line-numbers='true'] .code-line {
    counter-increment: codeline;
  }
  pre[data-line-numbers='true'] .code-line::before {
    content: counter(codeline);
    display: inline-block;
    width: 24px;
    color: var(--text-3);
    user-select: none;
    margin-right: 14px;
    text-align: right;
    font-family: var(--font-mono);
  }
  pre[data-line-numbers='true'] {
    counter-reset: codeline;
  }
  @media (max-width: 480px) {
    pre[data-line-numbers='true'] .code-line::before {
      display: none;
    }
    .code-body {
      padding: 14px 12px 14px;
      font-size: 12px;
    }
    .code-head {
      padding: 8px 12px;
    }
  }
</style>

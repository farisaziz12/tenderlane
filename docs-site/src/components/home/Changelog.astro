---
import Section from '../Section.astro';
import Icon from '../Icons.astro';

interface Release {
  name: string | null;
  tag_name: string;
  published_at: string;
  html_url: string;
  body: string | null;
}

let releases: Release[] = [];
try {
  const response = await fetch(
    'https://api.github.com/repos/farisaziz12/tenderlane/releases?per_page=3',
    { headers: { Accept: 'application/vnd.github+json' } },
  );
  if (response.ok) {
    const json = (await response.json()) as Release[];
    releases = Array.isArray(json) ? json.slice(0, 3) : [];
  }
} catch {
  releases = [];
}

const formatDate = (iso: string) => {
  try {
    return new Date(iso).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    });
  } catch {
    return '';
  }
};

const truncate = (text: string | null, max = 160) => {
  if (!text) return '';
  const cleaned = text.replace(/[\r\n]+/g, ' ').replace(/[#*`>_~]/g, '').trim();
  return cleaned.length > max ? `${cleaned.slice(0, max).trimEnd()}…` : cleaned;
};
---

<Section
  id="changelog"
  eyebrow="Changelog"
  title="Shipping in the open."
  kicker="Every tag is a GitHub Release with notes. The live npm registry is the source of truth for what's installable today."
>
  <div class="changelog-wrap">
    {releases.length > 0 ? (
      <ul class="changelog-list">
        {releases.map((r) => (
          <li class="changelog-row">
            <a class="changelog-link" href={r.html_url}>
              <div class="changelog-meta">
                <span class="changelog-tag">{r.tag_name}</span>
                <span class="changelog-date">{formatDate(r.published_at)}</span>
              </div>
              <div class="changelog-title">{r.name || r.tag_name}</div>
              {r.body && <p class="changelog-body">{truncate(r.body)}</p>}
              <span class="changelog-cta">
                read notes <Icon name="arrowExt" size={11} />
              </span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <div class="changelog-empty">
        <p>Release notes live on GitHub. The full history — every version, every fix, every breaking change — is one click away.</p>
      </div>
    )}
    <div class="changelog-foot">
      <a class="btn btn-ghost" href="https://github.com/farisaziz12/tenderlane/releases">
        View all releases <Icon name="arrowExt" size={12} />
      </a>
      <a class="btn btn-link" href="https://www.npmjs.com/org/tenderlane" style="color:var(--text-1)">
        Packages on npm <Icon name="arrowExt" size={12} />
      </a>
    </div>
  </div>
</Section>

<style>
  .changelog-wrap {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .changelog-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--line-2);
  }
  .changelog-row {
    border-bottom: 1px solid var(--line-2);
  }
  .changelog-link {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 20px 0;
    color: var(--text-0);
    transition: padding-left 0.2s;
  }
  .changelog-link:hover {
    padding-left: 12px;
  }
  .changelog-meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .changelog-tag {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    padding: 2px 8px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--accent) 10%, var(--bg-1));
    border: 1px solid var(--accent-soft);
  }
  .changelog-date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-3);
  }
  .changelog-title {
    font-size: 18px;
    font-weight: 500;
    color: var(--text-0);
  }
  .changelog-body {
    color: var(--text-2);
    font-size: 14px;
    line-height: 1.55;
    margin: 0;
    max-width: 720px;
  }
  .changelog-cta {
    margin-top: 4px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-2);
  }
  .changelog-empty {
    padding: 24px;
    border-radius: 12px;
    background: var(--bg-1);
    border: 1px solid var(--line-2);
    color: var(--text-1);
  }
  .changelog-empty p {
    margin: 0;
    max-width: 620px;
  }
  .changelog-foot {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  @media (max-width: 480px) {
    .changelog-link {
      padding: 16px 0;
    }
    .changelog-link:hover {
      padding-left: 0;
    }
    .changelog-title {
      font-size: 16px;
    }
    .changelog-body {
      font-size: 13px;
    }
    .changelog-foot .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

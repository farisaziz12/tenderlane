---
// SVG icon library, ported from the design.
interface Props {
  name:
    | 'search'
    | 'arrow'
    | 'arrowExt'
    | 'github'
    | 'discord'
    | 'check'
    | 'x'
    | 'minus'
    | 'copy'
    | 'diamond'
    | 'menu'
    | 'close';
  size?: number;
}
const { name, size = 14 } = Astro.props;
---

{name === 'search' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none">
    <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.3"></circle>
    <path d="M11 11l3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"></path>
  </svg>
)}
{name === 'arrow' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none">
    <path d="M4 8h8M8 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
  </svg>
)}
{name === 'arrowExt' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none">
    <path d="M5 11l6-6M11 5H6M11 5v5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
  </svg>
)}
{name === 'github' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2.1c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"></path>
  </svg>
)}
{name === 'discord' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M20.3 4.4A19 19 0 0 0 15.6 3l-.2.4c1.7.4 3 1.1 4.2 2-2-1-4-1.4-6-1.4s-4 .4-6 1.4c1.2-.9 2.5-1.5 4.2-2L11.6 3a19 19 0 0 0-4.7 1.4C3.4 9.6 2.4 14.6 2.9 19.5c2 1.4 3.9 2.3 5.7 2.9.4-.6.8-1.2 1.1-1.8-.7-.3-1.3-.6-1.9-1l.5-.4c3.7 1.7 7.7 1.7 11.4 0l.5.4c-.6.4-1.2.7-1.9 1 .3.6.7 1.2 1.1 1.8 1.9-.6 3.7-1.5 5.7-2.9.5-5.7-1-10.7-4.8-15.1zM9.5 16.4c-1.1 0-2-1-2-2.3 0-1.2.9-2.3 2-2.3s2 1 2 2.3c0 1.3-.9 2.3-2 2.3zm5 0c-1.1 0-2-1-2-2.3 0-1.2.9-2.3 2-2.3s2 1 2 2.3c0 1.3-.9 2.3-2 2.3z"></path>
  </svg>
)}
{name === 'check' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none">
    <path d="M3 8.5l3 3 7-7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
  </svg>
)}
{name === 'x' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none">
    <path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
  </svg>
)}
{name === 'minus' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none">
    <path d="M4 8h8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
  </svg>
)}
{name === 'copy' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none">
    <rect x="5" y="5" width="8" height="9" rx="1.2" stroke="currentColor" stroke-width="1.2"></rect>
    <path d="M3 11V3.2c0-.6.5-1.2 1.2-1.2H11" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
  </svg>
)}
{name === 'diamond' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none">
    <path d="M12 2 L22 12 L12 22 L2 12 Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
  </svg>
)}
{name === 'menu' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none">
    <path d="M2 4h12M2 8h12M2 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
  </svg>
)}
{name === 'close' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none">
    <path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
  </svg>
)}

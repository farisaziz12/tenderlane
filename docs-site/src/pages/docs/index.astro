---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icons.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const link = (p: string) => `${base}${p}`;

const packages = [
  { l: '@tenderlane/core', v: 'v0.4.0', ok: true },
  { l: '@tenderlane/client', v: 'v0.4.0', ok: true },
  { l: '@tenderlane/react', v: 'v0.4.0', ok: true },
  { l: '@tenderlane/stripe', v: 'v0.4.0', ok: true },
  { l: '@tenderlane/polar', v: 'v0.4.0', ok: true },
  { l: '@tenderlane/adyen', v: 'planned', planned: true },
];

const paths = [
  {
    l: 'I have a React app and a Stripe key.',
    sub: 'Drop in the provider. Render the form. Charge.',
    href: link('/docs/getting-started/quick-start'),
    time: '5 min',
    tag: 'GET STARTED',
  },
  {
    l: 'I need to route across 3+ markets.',
    sub: 'Rules, context, fallbacks, A/B tests.',
    href: link('/docs/cookbooks/country-based-routing'),
    time: '20 min',
    tag: 'COOKBOOK',
  },
  {
    l: "My PSP isn't Stripe.",
    sub: 'Polar today; write an adapter tomorrow. The provider contract is four methods.',
    href: link('/docs/cookbooks/polar-checkout-redirect'),
    time: '15 min',
    tag: 'COOKBOOK',
  },
];

const sections = [
  {
    l: 'Core concepts',
    color: 'var(--accent)',
    items: [
      { label: 'Routing', sub: 'first-match-wins', href: link('/docs/concepts/routing') },
      { label: 'Providers', sub: 'adapter contract', href: link('/docs/concepts/providers') },
      { label: 'Catalog', sub: 'provider-agnostic product+pricing', href: link('/docs/concepts/catalog') },
      { label: 'State machine', sub: 'idle → ready → submitting', href: link('/docs/concepts/state-machine') },
      { label: 'Middleware', sub: '3 lifecycle hooks', href: link('/docs/concepts/middleware') },
      { label: 'Type safety', sub: 'phantom-type provider IDs', href: link('/docs/concepts/type-safety') },
    ],
  },
  {
    l: 'Getting started',
    color: 'var(--info)',
    items: [
      { label: 'Introduction', sub: 'why this exists', href: link('/docs/getting-started/introduction') },
      { label: 'Installation', sub: 'pnpm add @tenderlane/*', href: link('/docs/getting-started/installation') },
      { label: 'Quick start', sub: 'first charge in 5 min', href: link('/docs/getting-started/quick-start') },
    ],
  },
  {
    l: 'Cookbooks',
    color: 'var(--text-2)',
    items: [
      { label: 'Stripe Checkout redirect', sub: '', href: link('/docs/cookbooks/stripe-checkout-redirect') },
      { label: 'Polar Checkout redirect', sub: '', href: link('/docs/cookbooks/polar-checkout-redirect') },
      { label: 'Stripe Elements inline', sub: '', href: link('/docs/cookbooks/stripe-elements-inline') },
      { label: 'A/B testing payment flows', sub: '', href: link('/docs/cookbooks/ab-testing-payment-flows') },
      { label: 'Middleware analytics', sub: '', href: link('/docs/cookbooks/middleware-analytics') },
      { label: 'Next.js App Router', sub: '', href: link('/docs/cookbooks/nextjs-app-router') },
    ],
  },
];
---

<Layout title="Docs · Tenderlane" active="docs" mode="docs" description="From npm install to your first charge. Tenderlane docs, guides, and recipes.">
  <div class="docs-landing">
    <div class="container">
      <div class="hero-row">
        <div>
          <div class="t-eyebrow" style="margin-bottom:22px"><span class="dot"></span>Docs</div>
          <h1 class="t-display landing-h1">
            From <span class="t-mono" style="font-weight:500;letter-spacing:-0.02em">npm i</span> to your first <span style="color:var(--accent)">charge</span>.
          </h1>
          <p class="t-body-lg" style="margin:0 0 32px;max-width:540px">
            Five minutes to a working multi-region React checkout. Read what you need; the rest is here when you do.
          </p>
          <div class="hero-row-actions">
            <div class="install-pill">
              <span style="color:var(--text-3)">$</span>
              <span><span style="color:var(--accent)">pnpm</span> add @tenderlane/core @tenderlane/react @tenderlane/stripe</span>
              <span style="width:1px;height:14px;background:var(--line-2)"></span>
              <button class="btn btn-link" style="padding:0;color:var(--text-2)" aria-label="Copy">
                <Icon name="copy" size={13} />
              </button>
            </div>
            <a href={link('/docs/getting-started/quick-start')} class="btn btn-primary">
              5-minute quickstart <Icon name="arrow" size={12} />
            </a>
          </div>
        </div>
        <div class="status-panel">
          <div class="t-cap" style="margin-bottom:14px;color:var(--text-3)">STATUS · live</div>
          <div style="display:flex;flex-direction:column;gap:12px">
            {packages.map((p) => (
              <div class="pkg-row">
                <span style={`font-family:var(--font-mono);font-size:12px;color:${p.planned ? 'var(--text-3)' : 'var(--text-0)'}`}>{p.l}</span>
                <span style={`font-family:var(--font-mono);font-size:11px;color:${p.ok ? 'var(--accent)' : 'var(--text-3)'}`}>{p.v}</span>
              </div>
            ))}
          </div>
          <div class="pkg-foot">
            <span>alpha · v0.4</span>
            <a href="https://github.com/farisaziz12/tenderlane/releases" style="color:var(--text-2)">releases →</a>
          </div>
        </div>
      </div>

      <div class="t-cap" style="margin-bottom:24px;color:var(--text-3)">PICK A PATH</div>
      <div class="path-grid">
        {paths.map((c) => (
          <a href={c.href} class="path-card">
            <div class="path-head">
              <span class="t-cap" style="color:var(--accent)">{c.tag}</span>
              <span class="t-cap" style="color:var(--text-3)">{c.time}</span>
            </div>
            <div class="path-title">{c.l}</div>
            <p style="margin:0;font-size:13px;color:var(--text-2)">{c.sub}</p>
            <div class="path-foot">Open guide →</div>
          </a>
        ))}
      </div>

      <div class="section-grid">
        {sections.map((s) => (
          <div class="section-col">
            <div class="t-cap section-col-head" style={`color:${s.color}`}>
              <span style={`display:inline-block;width:6px;height:6px;border-radius:50%;background:${s.color};margin-right:8px`}></span>{s.l}
            </div>
            <ul class="section-list">
              {s.items.map((i) => (
                <li>
                  <a href={i.href}>
                    <span>{i.label}</span>
                    <span style="color:var(--text-3);font-size:12px;font-family:var(--font-mono)">{i.sub}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="cta-bar">
        <div>
          <div class="t-cap" style="margin-bottom:8px;color:var(--text-3)">NEW · v0.4</div>
          <div style="font-size:22px;font-weight:500;margin-bottom:6px">Catalog primitive + Polar adapter.</div>
          <p style="margin:0;color:var(--text-1);font-size:14px">
            One SKU can target multiple PSPs. Server re-resolves at submit — the PSP dashboard is the source of truth for money.
          </p>
        </div>
        <div style="display:flex;gap:12px;flex-wrap:wrap">
          <a class="btn btn-ghost" href={link('/docs/concepts/catalog')}>Catalog</a>
          <a class="btn btn-primary" href={link('/docs/cookbooks/polar-checkout-redirect')}>Polar guide <Icon name="arrow" size={12} /></a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .docs-landing {
    padding: 80px var(--side-pad) 100px;
    padding-left: max(var(--side-pad), env(safe-area-inset-left));
    padding-right: max(var(--side-pad), env(safe-area-inset-right));
  }
  .hero-row {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: 64px;
    align-items: center;
    margin-bottom: 80px;
  }
  .hero-row > * {
    min-width: 0;
  }
  .landing-h1 {
    font-size: clamp(40px, 5.5vw, 64px);
    line-height: 1;
    margin: 0 0 24px;
    letter-spacing: -0.032em;
  }
  .hero-row-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }
  .install-pill {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 12px 18px;
    background: var(--bg-1);
    border: 1px solid var(--line-2);
    border-radius: 8px;
    font: 500 14px var(--font-mono);
    color: var(--text-1);
    max-width: 100%;
    overflow-x: auto;
  }
  .status-panel {
    padding: 24px;
    border-radius: 14px;
    background: var(--bg-1);
    border: 1px solid var(--line-2);
  }
  .pkg-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 12px;
    background: var(--bg-2);
    border-radius: 6px;
  }
  .pkg-foot {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--line-1);
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-3);
  }
  .path-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
    margin-bottom: 80px;
  }
  .path-grid > * {
    min-width: 0;
  }
  .path-card {
    padding: 28px;
    border-radius: 14px;
    background: var(--bg-1);
    border: 1px solid var(--line-2);
    color: var(--text-0);
    display: flex;
    flex-direction: column;
    transition:
      border-color 0.15s,
      transform 0.15s;
  }
  .path-card:hover {
    border-color: var(--line-3);
    transform: translateY(-2px);
  }
  .path-head {
    display: flex;
    justify-content: space-between;
    margin-bottom: 18px;
  }
  .path-title {
    font-size: 20px;
    font-weight: 500;
    margin-bottom: 10px;
    letter-spacing: -0.012em;
  }
  .path-foot {
    margin-top: 24px;
    color: var(--accent);
    font-size: 13px;
    font-family: var(--font-mono);
  }
  .section-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 32px;
    margin-bottom: 80px;
  }
  .section-grid > * {
    min-width: 0;
  }
  .section-col {
    border-top: 1px solid var(--line-2);
    padding-top: 24px;
  }
  .section-col-head {
    margin-bottom: 18px;
    display: flex;
    align-items: center;
  }
  .section-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .section-list a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid var(--line-1);
    font-size: 14px;
    color: var(--text-0);
    gap: 16px;
  }
  .section-list a:hover {
    color: var(--accent);
  }
  .cta-bar {
    padding: 36px;
    border-radius: 14px;
    background: var(--bg-1);
    border: 1px solid var(--line-2);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }
  @media (max-width: 1000px) {
    .hero-row,
    .path-grid,
    .section-grid {
      grid-template-columns: minmax(0, 1fr);
    }
    .hero-row {
      gap: 40px;
      margin-bottom: 56px;
    }
    .path-grid,
    .section-grid {
      margin-bottom: 56px;
    }
  }
  @media (max-width: 900px) {
    .docs-landing {
      padding-top: 56px;
      padding-bottom: 64px;
    }
  }
  @media (max-width: 480px) {
    .docs-landing {
      padding-top: 40px;
      padding-bottom: 48px;
    }
    .hero-row {
      margin-bottom: 40px;
      gap: 28px;
    }
    .install-pill {
      font-size: 12px;
      padding: 10px 14px;
      gap: 8px;
    }
    .hero-row-actions .btn {
      width: 100%;
      justify-content: center;
    }
    .status-panel {
      padding: 18px;
    }
    .pkg-row {
      gap: 8px;
    }
    .pkg-row > span {
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .path-card {
      padding: 20px;
    }
    .path-title {
      font-size: 18px;
    }
    .path-foot {
      margin-top: 18px;
    }
    .path-grid,
    .section-grid {
      margin-bottom: 40px;
    }
    .cta-bar {
      padding: 22px;
      gap: 20px;
    }
    .cta-bar .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

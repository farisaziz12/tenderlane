# Stripe — required.
# Get your keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price ID (optional but recommended).
# When set, the server registers a Stripe-sourced catalog
# (`createStripeCatalog`) for the 'premium-plan' SKU. The server calls
# `stripe.prices.retrieve(priceId)` at submit time — pricing comes from the
# Stripe dashboard, NOT from this codebase.
# When unset, the example has no Stripe-side catalog. The server returns
# 400 for Stripe checkouts (no fallback inline pricing in this demo).
# STRIPE_PRICE_ID=price_xxx

# Polar — optional. The Polar provider is only registered server-side when
# POLAR_ACCESS_TOKEN, POLAR_ORGANIZATION_ID, and POLAR_PRODUCT_ID are all set.
# When set, the server registers a Polar-sourced catalog
# (`createPolarCatalog`) for the 'premium-plan' SKU — `polar.products.get(...)`
# pulls the canonical product + price from Polar at submit time.
# Without these, the app still works with Stripe only.
# Create an Organization Access Token at https://sandbox.polar.sh (or
# https://polar.sh for production) and create one product to get the ID.
# POLAR_ACCESS_TOKEN=polar_oat_...
# POLAR_ORGANIZATION_ID=org_xxx
# POLAR_PRODUCT_ID=polar_prod_xxx

# Which Polar environment to talk to. Default: sandbox.
# POLAR_ENVIRONMENT=sandbox

# Expose the Polar org ID to the client so the browser provider knows which
# org to scope to. Should match POLAR_ORGANIZATION_ID above.
# NEXT_PUBLIC_POLAR_ORGANIZATION_ID=org_xxx
